---
const categories = [
  {
    title: "Frontend",
    items: ["React", "Next.js", "TypeScript", "Astro", "Tailwind CSS", "HTML/CSS"],
  },
  {
    title: "Backend",
    items: ["Node.js", "Express", "MySQL", "PostgreSQL", "REST APIs", "GraphQL"],
  },
  {
    title: "Tools",
    items: ["Git", "Docker", "Figma", "VS Code", "Vite", "pnpm"],
  },
];
---

<section id="skills" class="relative border-t border-border py-20 md:py-28" aria-labelledby="skills-heading">
  <div class="mx-auto max-w-6xl px-4 md:px-6">
    <h2 id="skills-heading" class="section-reveal mb-4 text-center text-3xl font-bold tracking-tight text-foreground md:text-4xl" data-section-reveal>
      Skills &amp; Tech Stack
    </h2>
    <p class="section-reveal mx-auto mb-12 max-w-2xl text-center text-muted-foreground" data-section-reveal>
      Technologies I use to build modern, scalable applications.
    </p>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {categories.map((category, i) => (
        <div
          class="section-reveal card-hover-lift rounded-2xl border border-border bg-card/50 p-6 shadow-lg"
          data-section-reveal
          style={`animation-delay: ${i * 0.1}s`}
        >
          <h3 class="mb-4 text-lg font-semibold text-foreground">{category.title}</h3>
          <div class="flex flex-wrap gap-2">
            {category.items.map((skill) => (
              <span class="rounded-lg bg-primary/15 px-3 py-1.5 text-sm font-medium text-foreground ring-1 ring-primary/20 transition-colors hover:bg-primary/25 hover:ring-primary/40">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
