---
---

<section id="home" class="relative min-h-screen overflow-hidden pt-20 pb-16 md:pt-28 md:pb-24">
  <!-- Background glow -->
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(79,70,229,0.35),transparent)]" aria-hidden="true"></div>
  <div class="pointer-events-none absolute right-0 top-1/4 h-[400px] w-[400px] rounded-full bg-primary/10 blur-[120px]" aria-hidden="true"></div>
  <div class="pointer-events-none absolute bottom-0 left-1/4 h-[300px] w-[300px] rounded-full bg-[#06b6d4]/10 blur-[100px]" aria-hidden="true"></div>

  <div class="relative mx-auto flex max-w-6xl flex-col items-center px-4 md:flex-row md:items-center md:justify-between md:gap-12 md:px-6">
    <div class="max-w-2xl text-center md:text-left">
      <p class="mb-4 text-sm font-semibold uppercase tracking-wider text-primary" data-section-reveal>
        Web Developer
      </p>
      <h1 class="mb-6 text-4xl font-bold leading-[1.15] tracking-tight text-foreground md:text-5xl lg:text-6xl" data-section-reveal>
        Building Scalable &amp; Modern
        <span class="portfolio-gradient-text"> Web Applications</span>
      </h1>
      <p class="mb-8 text-lg text-muted-foreground md:text-xl" data-section-reveal>
        I craft performant, accessible web experiences with modern stacks. Problem-solving through clean code and thoughtful architecture.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4 md:justify-start" data-section-reveal>
        <a href="#projects" class="btn-gradient inline-flex items-center gap-2 rounded-lg px-6 py-3 text-base font-semibold shadow-lg">
          View Projects
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="/cv.pdf"
          download
          class="inline-flex items-center gap-2 rounded-lg border border-border bg-card/50 px-6 py-3 text-base font-semibold text-foreground transition-colors hover:bg-white/5"
        >
          Download CV
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Abstract shape / visual -->
    <div class="mt-12 flex-shrink-0 md:mt-0 md:w-[380px] lg:w-[440px]" data-section-reveal aria-hidden="true">
      <div class="relative mx-auto aspect-square max-w-[280px] md:max-w-none">
        <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-primary/30 to-[#06b6d4]/30 blur-2xl"></div>
        <div class="relative flex h-full w-full items-center justify-center rounded-3xl border border-white/10 bg-card/50 shadow-2xl backdrop-blur-sm">
          <div class="flex h-3/4 w-3/4 flex-wrap items-center justify-center gap-4 p-6">
            <div class="h-14 w-14 rounded-xl bg-primary/20 shadow-inner"></div>
            <div class="h-12 w-12 rounded-lg bg-[#06b6d4]/20 shadow-inner"></div>
            <div class="h-16 w-16 rounded-2xl bg-primary/15 shadow-inner"></div>
            <div class="h-10 w-10 rounded-lg bg-[#06b6d4]/25 shadow-inner"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
