---
const experiences = [
  {
    company: "Tech Company Inc.",
    role: "Senior Web Developer",
    duration: "2022 – Present",
    achievements: [
      "Led frontend architecture for a flagship SaaS product serving 50k+ users.",
      "Introduced TypeScript and design system, reducing bugs and improving delivery time.",
      "Mentored 3 junior developers and established code review practices.",
    ],
  },
  {
    company: "Startup Labs",
    role: "Full-Stack Developer",
    duration: "2020 – 2022",
    achievements: [
      "Built and maintained REST APIs and admin dashboards for multiple client projects.",
      "Improved API response times by 40% through query optimization and caching.",
      "Collaborated with design and product teams in an agile environment.",
    ],
  },
  {
    company: "Digital Agency",
    role: "Frontend Developer",
    duration: "2018 – 2020",
    achievements: [
      "Developed responsive, accessible websites for brands across e-commerce and healthcare.",
      "Implemented A/B tests and analytics to improve conversion rates.",
      "Contributed to internal component library and documentation.",
    ],
  },
];
---

<section id="experience" class="relative border-t border-border py-20 md:py-28" aria-labelledby="experience-heading">
  <div class="mx-auto max-w-4xl px-4 md:px-6">
    <h2 id="experience-heading" class="section-reveal mb-4 text-center text-3xl font-bold tracking-tight text-foreground md:text-4xl" data-section-reveal>
      Experience
    </h2>
    <p class="section-reveal mx-auto mb-14 max-w-2xl text-center text-muted-foreground" data-section-reveal>
      Roles and impact over the years.
    </p>

    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-4 top-0 bottom-0 w-px bg-gradient-to-b from-primary/50 via-primary/30 to-transparent md:left-1/2 md:-translate-x-px" aria-hidden="true"></div>

      <ul class="space-y-12" role="list">
        {experiences.map((exp, i) => (
          <li class="section-reveal relative flex gap-8 md:gap-12" data-section-reveal>
            <div class="absolute left-4 flex h-3 w-3 -translate-x-1/2 items-center justify-center rounded-full border-2 border-primary bg-background md:left-1/2" aria-hidden="true"></div>
            <div class="ml-10 flex-1 md:ml-0 md:pr-12 md:text-right">
              <span class="text-sm font-semibold text-primary">{exp.duration}</span>
              <h3 class="mt-1 text-lg font-bold text-foreground">{exp.role}</h3>
              <p class="text-muted-foreground">{exp.company}</p>
            </div>
            <div class="ml-10 flex-[1.2] md:ml-12 md:pl-12 md:text-left">
              <ul class="space-y-2 text-muted-foreground" role="list">
                {exp.achievements.map((achievement) => (
                  <li class="flex gap-2">
                    <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-primary/60" aria-hidden="true"></span>
                    <span>{achievement}</span>
                  </li>
                ))}
              </ul>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
